@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<link rel="stylesheet" href="~/css/LoginRegister.css" />

<div class="auth-page-wrapper">
    <div class="auth-box">
        <h2 class="auth-title">Login</h2>
        
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="color: red; font-size: 0.9em; margin-bottom: 15px; text-align: left;"></div>
            
            <div class="input-group">
                <input asp-for="Input.UserName" required placeholder=" " autocomplete="username" />
                <label asp-for="Input.UserName">Username</label>
                <span asp-validation-for="Input.UserName" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>
            
            <div class="input-group">
                <input asp-for="Input.Password" required placeholder=" " autocomplete="current-password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>

            <button type="submit" class="auth-choice-btn btn-solid">
                Login
            </button>
            
            <div style="margin-top: 20px;">
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="back-link-auth">Register as a new user</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
