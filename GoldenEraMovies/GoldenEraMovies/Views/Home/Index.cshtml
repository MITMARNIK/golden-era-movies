@model IEnumerable<GoldenEraMovies.Models.Movie>

@{
    ViewData["Title"] = "Home Page";
}

@if (TempData["Message"] != null)
{
    <div style="background: #d4edda; color: #155724; padding: 15px; border-radius: 10px; margin: 20px auto; max-width: 900px; text-align: center; border: 1px solid #c3e6cb;">
        @TempData["Message"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div style="background: #f8d7da; color: #721c24; padding: 15px; border-radius: 10px; margin: 20px auto; max-width: 900px; text-align: center; border: 1px solid #f5c6cb;">
        @TempData["Error"]
    </div>
}
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="movies-container">
    <h2 class="section-title">Top Rated Movies</h2>

    <div class="movies-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var movie in Model)
            {
                <div class="movie-card">
                    <img src="@movie.PosterPath" alt="@movie.Title">
                    <h3>@movie.Title</h3>
                    <p>Rating: @movie.AverageRating/10</p>
                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.MovieId" class="btn-vezi">View Details</a>  
                </div>
            }
        }
        else
        {
            <p>No movies available at the moment.</p>
        }
    </div>
</div>
<div style="text-align: center; margin-top: 50px; color: #555; font-size: 12px; padding-bottom: 20px;">
    System Update: @ViewBag.LastSync (Automatic Sync Active)
</div>
