@model IEnumerable<GoldenEraMovies.Models.Movie>

@{
    ViewData["Title"] = "My Watchlist";
}

<link rel="stylesheet" href="~/css/movies.css" asp-append-version="true" />

<div class="container" style="max-width: 1000px; margin: 30px auto;">
    <h2 style="color: #2c2c2c; text-align: center; margin-bottom: 30px; text-transform: uppercase;">My Watchlist</h2>
    
    <div class="movie-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="movie-list-item">
                    <img src="@item.PosterPath" alt="Poster @item.Title">
                    <div class="movie-info">
                        <h3>@item.Title</h3>
                        <p class="movie-meta">Rating: @item.AverageRating/5.00</p>
                        <p class="movie-desc">@item.Description</p>
                    </div>
                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@item.MovieId" class="btn-vezi">View Details</a>
                </div>
            }
        }
        else
        {
            <div class="movie-list-item" style="justify-content: center; padding: 50px;">
                <p style="color: white; text-align: center;">Your watchlist is empty. Go find some classics!</p>      
            </div>
        }
    </div>

    <div style="text-align: center; margin-top: 30px;">
        <a asp-action="Profile" class="btn-vezi" style="border-color: #2c2c2c; color: #2c2c2c;">Back to Profile</a>
    </div>
</div>
