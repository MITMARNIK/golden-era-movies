@model GoldenEraMovies.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<link rel="stylesheet" href="~/css/Profile.css" asp-append-version="true" />

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">@Model.Username.Substring(0, 1).ToUpper()</div>
        <div class="profile-info">
            <h1>@Model.Username</h1>
            <div class="user-stats">
                <span><strong>@((ViewBag.RecentWatchlist as List<Movie>)?.Count ?? 0)</strong> Recently Added</span>
            </div>
        </div>
    </div>

    <div class="profile-content">
        <div class="content-section">
            <h2>Recently Added to Watchlist</h2>
            <div class="mini-movie-grid">
                @if (ViewBag.RecentWatchlist != null)
                {
                    @foreach (var movie in (List<Movie>)ViewBag.RecentWatchlist)
                    {
                        <div class="mini-card">
                            <img src="@movie.PosterPath" alt="@movie.Title">
                            <span>@movie.Title</span>
                        </div>
                    }
                }
                else
                {
                    <p style="color: #666;">No movies in watchlist yet.</p>
                }
            </div>
        </div>

        <div class="content-section">
            <h2>Account Settings</h2>
            <ul class="settings-list">
                <li><a asp-controller="Account" asp-action="ChangePassword" style="color: inherit; text-decoration: none;">Change Password</a> <span>&rsaquo;</span></li>
                <li>
                    <a asp-controller="Home" asp-action="Watchlist" class="profile-link">Watchlist</a>
                    <span>&rsaquo;</span>
                </li>
                <li>
                    <div>
                        <a asp-controller="Home" asp-action="SyncData" style="color: #ffc107; text-decoration: none; font-weight: bold;">Sync Classics (TMDB)</a>
                        <br /><small style="color: #888; font-size: 11px;">Last auto-sync: @ViewBag.LastSync</small>
                    </div>
                    <span>&rsaquo;</span>
                </li>
                <li class="logout">
                    <a asp-controller="Account" asp-action="Logout" style="color: inherit; text-decoration: none; width: 100%; display: block;">Log Out</a>
                </li>
            </ul>
        </div>
    </div>
</div>
