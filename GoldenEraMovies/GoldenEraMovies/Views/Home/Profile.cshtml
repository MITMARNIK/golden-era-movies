@model GoldenEraMovies.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<link rel="stylesheet" href="~/css/Profile.css" asp-append-version="true" />

<div class="profile-container">
    <div class="profile-header" style="flex-direction: column; align-items: center; text-align: center;">
        <div class="profile-avatar" style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #c5a85c; color: #111; font-size: 3em;">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" alt="Profile Picture" style="width: 100%; height: 100%; object-fit: cover;" />
            }
            else
            {
                @Model.UserName.Substring(0, 1).ToUpper()
            }
        </div>
        
        <div style="margin-top: 15px;">
            <a asp-action="EditProfile" class="btn-vezi" style="padding: 8px 20px; width: auto; display: inline-block; font-size: 14px; background: linear-gradient(135deg, #c5a85c 0%, #a68434 100%); text-decoration: none; border-radius: 5px;">Edit Profile</a>
        </div>

        <div class="profile-info" style="margin-top: 20px;">
            <h1 style="color: #c5a85c; text-shadow: 1px 1px 2px black;">@Model.UserName</h1>
            <div class="user-stats" style="justify-content: center;">
                <span><strong>@((ViewBag.RecentWatchlist as List<Movie>)?.Count ?? 0)</strong> Recently Added</span>
            </div>
        </div>
    </div>

    <div class="profile-content">
        <div class="content-section">
            <h2>Recently Added to Watchlist</h2>
            <div class="mini-movie-grid">
                @if (ViewBag.RecentWatchlist != null)
                {
                    @foreach (var movie in (List<Movie>)ViewBag.RecentWatchlist)
                    {
                        <div class="mini-card">
                            <img src="@movie.PosterPath" alt="@movie.Title">
                            <span>@movie.Title</span>
                        </div>
                    }
                }
                else
                {
                    <p style="color: #666;">No movies in watchlist yet.</p>
                }
            </div>
        </div>

        <div class="content-section">
            <h2>Account Settings</h2>
            <ul class="settings-list">
                <li>
                    <a asp-controller="Home" asp-action="Watchlist" class="profile-link">Watchlist</a>
                    <span>&rsaquo;</span>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a asp-controller="Admin" asp-action="Index" class="profile-link" style="color: #ffc107; font-weight: bold;">Users</a>
                        <span>&rsaquo;</span>
                    </li>
                }

                <li class="logout">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" style="width: 100%; margin: 0;">
                        <button type="submit" style="background: none; border: none; color: inherit; width: 100%; text-align: left; padding: 0; font: inherit; cursor: pointer;">Log Out</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</div>
