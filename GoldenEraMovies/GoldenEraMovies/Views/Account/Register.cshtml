@model GoldenEraMovies.Models.User

@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="~/css/LoginRegister.css" asp-append-version="true" />

<div class="auth-page-wrapper">
    <div class="auth-box"> 
        <h2 class="auth-title">Join <span>Golden Era</span></h2>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px; font-size: 14px;"></div>

            <div class="input-group">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" placeholder="Choose a username" required>
                <span asp-validation-for="Username" class="text-danger" style="font-size: 12px; color: #ff4444; display: block; margin-top: 5px;"></span>
            </div>

            <div class="input-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="Choose a password" required>
                <span asp-validation-for="Password" class="text-danger" style="font-size: 12px; color: #ff4444; display: block; margin-top: 5px;"></span>
            </div>

            <button type="submit" class="auth-choice-btn btn-outline" style="margin-top: 20px;">Create an Account</button>
        </form>

        <a asp-action="Index" class="back-link-auth" style="margin-top: 20px; display: block;">&larr; Back to Choice</a>
    </div>
</div>
