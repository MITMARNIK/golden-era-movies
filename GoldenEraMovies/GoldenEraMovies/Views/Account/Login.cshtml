@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/LoginRegister.css" asp-append-version="true" />

<div class="auth-page-wrapper">
    <div class="auth-box"> 
        <h2 class="auth-title">Welcome Back to <span>Golden Era</span></h2>

        <form>
            <div class="input-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" placeholder="Enter your email" required>
            </div>

            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" placeholder="Enter your password" required>
            </div>

            <button type="submit" class="auth-choice-btn btn-solid">Login</button>
        </form>

        <a asp-action="Index" class="back-link-auth">&larr; Back to Choice</a>
    </div>
</div>
