@model GoldenEraMovies.Models.User

@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/LoginRegister.css" asp-append-version="true" />

<div class="auth-page-wrapper">
    <div class="auth-box"> 
        <h2 class="auth-title">Welcome Back to <span>Golden Era</span></h2>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px; font-size: 14px;"></div>

            <div class="input-group">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" placeholder="Enter your username" required>
            </div>

            <div class="input-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="Enter your password" required>
            </div>

            <button type="submit" class="auth-choice-btn btn-solid" style="margin-top: 20px;">Login</button>
        </form>

        <a asp-action="Index" class="back-link-auth" style="margin-top: 20px; display: block;">&larr; Back to Choice</a>
    </div>
</div>
