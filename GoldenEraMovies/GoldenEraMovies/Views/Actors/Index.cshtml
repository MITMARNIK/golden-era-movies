@model IEnumerable<GoldenEraMovies.Models.Actor>
@{ ViewData["Title"] = "Actors Management"; }
<h1>Actors Management</h1>
<p><a asp-action="Create" class="btn btn-primary">Add New Actor</a></p>
<table class="table">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Oscar Awards</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.FullName)</td>
            <td>@Html.DisplayFor(modelItem => item.OscarAwards)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ActorId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ActorId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ActorId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
