@model IEnumerable<GoldenEraMovies.Models.Actor>

@{
    ViewData["Title"] = "Golden Era Actors";
}

<link rel="stylesheet" href="~/css/actors.css" asp-append-version="true" />

<div class="actors-container">
    <h2 class="section-title">Hall of Fame: Actors</h2>
    
    @if (User.IsInRole("Admin"))
    {
        <div style="text-align: center; margin-bottom: 30px;">
            <a asp-action="Create" class="btn-vezi" style="background: linear-gradient(135deg, #28a745 0%, #218838 100%); width: auto; padding: 10px 20px; display: inline-block;">+ Add Actor</a>
        </div>
    }
    
    <div class="actors-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var actor in Model)
            {
                <div class="actor-card">
                    <img src="@(string.IsNullOrEmpty(actor.ImagePath) || actor.ImagePath.Contains("null") ? "https://images.placeholders.dev/?width=300&height=450&text=No+Photo&bgColor=%232c2c2c&textColor=%23ffc107" : actor.ImagePath)" alt="@actor.FullName">
                    <h3>@actor.FullName</h3>

                    <p class="actor-bio-short">@(string.IsNullOrEmpty(actor.Bio) ? "Biography currently unavailable for this Golden Era star." : (actor.Bio.Length > 100 ? actor.Bio.Substring(0, 97) + "..." : actor.Bio))</p>
                    <a asp-action="Details" asp-route-id="@actor.ActorId" class="btn-vezi">View Biography</a>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@actor.ActorId" method="post" style="margin-top: 10px;" onsubmit="return confirm('Are you sure you want to delete this actor?');">
                            <button type="submit" class="btn-vezi" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); width: 100%; border: none; cursor: pointer;">Delete Actor</button>
                        </form>
                    }
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; padding: 50px; color: #888;">
                <p>No actors found in the database. Stay tuned for legendary updates!</p>
            </div>
        }
    </div>
</div>
