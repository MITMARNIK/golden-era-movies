@model GoldenEraMovies.Models.Actor
@{ ViewData["Title"] = "Actor Details"; }
<h1>Actor Details</h1>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.FullName)</dd>
        <dt class="col-sm-2">Oscar Awards</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OscarAwards)</dd>
        <dt class="col-sm-2">Bio</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Bio)</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.ActorId" class="btn btn-primary">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
