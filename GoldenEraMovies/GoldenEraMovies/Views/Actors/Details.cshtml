@model GoldenEraMovies.Models.Actor

@{
    ViewData["Title"] = Model.FullName;
}

<style>
    .actor-details-container {
        max-width: 900px;
        margin: 50px auto;
        display: flex;
        gap: 40px;
        background-color: #2c2c2c;
        border-radius: 20px;
        padding: 40px;
        border: 2px solid #ffc107;
        box-shadow: 0 15px 40px rgba(0,0,0,0.5);
    }

    .actor-poster {
        flex: 0 0 350px;
    }

    .actor-poster img {
        width: 100%;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.4);
    }

    .actor-info {
        flex: 1;
    }

    .actor-name {
        color: #ffc107;
        font-size: 38px;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-weight: bold;
    }

    .actor-meta {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        color: #ccc;
        font-size: 16px;
    }

    .oscar-count {
        background: rgba(255, 193, 7, 0.1);
        padding: 5px 15px;
        border-radius: 20px;
        border: 1px solid #ffc107;
        color: #ffc107;
    }

    .actor-bio-title {
        color: #ffc107;
        font-size: 22px;
        margin-bottom: 15px;
        border-bottom: 1px solid rgba(255,193,7,0.3);
        display: inline-block;
        padding-bottom: 5px;
    }

    .actor-bio-content {
        color: #ddd;
        line-height: 1.8;
        font-size: 17px;
        text-align: justify;
    }

    .back-btn {
        display: inline-block;
        margin-top: 30px;
        color: #ffc107;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

    .back-btn:hover {
        transform: translateX(-5px);
    }
</style>

<div class="actor-details-container">
    <div class="actor-poster">
        <img src="@(string.IsNullOrEmpty(Model.ImagePath) || Model.ImagePath.Contains("null") ? "https://images.placeholders.dev/?width=400&height=600&text=No+Photo+Available&bgColor=%232c2c2c&textColor=%23ffc107" : Model.ImagePath)" alt="@Model.FullName">
    </div>

    <div class="actor-info">
        <h1 class="actor-name">@Model.FullName</h1>
        


        <h3 class="actor-bio-title">Biography</h3>
        <p class="actor-bio-content">
            @(string.IsNullOrEmpty(Model.Bio) ? "Biography currently unavailable for this Golden Era star. We are working hard to bring you more details about their legendary career!" : Model.Bio)
        </p>

        <a asp-action="Index" class="back-btn">&larr; Back to Actors List</a>
    </div>
</div>
