@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Golden Era</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="container">
            <ul class="custom-navbar">
                <li class="navbar-logo">
                    <a asp-controller="Home" asp-action="Profile">
                        <img src="~/Imagini/GoldenEra.png" alt="Golden Era Logo">
                    </a>
                </li>
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Movies" asp-action="Index">Movies</a></li>
                <li><a asp-controller="Movies" asp-action="Top">Top Movies</a></li>
                <li><a asp-controller="Actors" asp-action="Index">Actors</a></li>
                @if (Context.Session.GetString("UserSession") != null)
                {
                    <li><a asp-controller="Home" asp-action="Profile">Profile</a></li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="Index">Login/Register</a></li>
                }
                <li class="search-item">
                    <form asp-controller="Home" asp-action="Search" method="get" class="search-box">
                        <input type="text" name="query" placeholder="Search movies, actors, genres...">
                        <button type="submit">🔍</button>
                    </form>
                </li>
            </ul>
        </div>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container" style="text-align: center; padding: 5px;">
            &copy; 2026 - Golden Era Movies
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

