@model IEnumerable<GoldenEraMovies.Models.Genre>
@{ ViewData["Title"] = "Genres Management"; }
<h1>Genres Management</h1>
<p><a asp-action="Create" class="btn btn-primary">Create New Genre</a></p>
<table class="table">
    <thead><tr><th>Name</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.GenreId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.GenreId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.GenreId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
