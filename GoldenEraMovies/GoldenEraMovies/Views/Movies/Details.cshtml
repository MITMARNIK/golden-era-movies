@model GoldenEraMovies.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="~/css/movieTemplate.css" asp-append-version="true" />

<div class="movie-details-container">

    <div class="details-poster">
        <img src="@(string.IsNullOrEmpty(Model.PosterPath) || Model.PosterPath.Contains("null") ? "https://images.placeholders.dev/?width=400&height=600&text=No+Poster+Available&bgColor=%232c2c2c&textColor=%23ffc107" : Model.PosterPath)" alt="Poster @Model.Title">
    </div>

    <div class="details-info">
        <h1 class="details-title">@Model.Title</h1>

        <div class="details-meta">
            <span class="meta-item">Release Year: @Model.ReleaseYear</span>
            <span class="meta-item">Duration: @Model.Duration min</span>
            <span class="meta-item">Genre: @(Model.Genre?.Name ?? "N/A")</span>
            <span class="meta-rating">⭐ @Model.AverageRating/5.00</span>
        </div>

        <div class="user-vote-section">
            <span class="vote-text">Rate this movie:</span>
            <div class="star-rating">
                <span class="star" data-value="5">★</span>
                <span class="star" data-value="4">★</span>
                <span class="star" data-value="3">★</span>
                <span class="star" data-value="2">★</span>
                <span class="star" data-value="1">★</span>
            </div>
        </div>

        <h3 class="details-subtitle">Synopsis</h3>
        <p class="details-synopsis">
            @(string.IsNullOrEmpty(Model.Description) ? "Synopsis currently unavailable for this classic masterpiece. We are working to uncover more details about this historical gem!" : Model.Description)
        </p>

        <div class="details-actions">
            <a asp-controller="Movies" asp-action="AddToWatchlist" asp-route-id="@Model.MovieId" class="btn-vezi">+ Add to Watchlist</a>
            <a asp-controller="Home" asp-action="Index" class="btn-vezi">Back to List</a>
        </div>

    </div>
</div>

<link rel="stylesheet" href="~/css/commentsTemplate.css" asp-append-version="true" />
<style>
    /* Custom golden era style overrides for details integration */
    .comments-details-section {
        max-width: 1200px;
        margin: 40px auto;
        background: rgba(30, 30, 30, 0.6);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 215, 0, 0.15);
        border-radius: 20px;
        padding: 45px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    }
    
    .comments-section-title {
        color: #ffc107;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 30px;
        border-bottom: 2px solid rgba(255, 215, 0, 0.15);
        padding-bottom: 15px;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .login-prompt-box {
        background: rgba(255, 215, 0, 0.05);
        border: 1px dashed rgba(255, 215, 0, 0.3);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        margin-bottom: 40px;
    }

    .login-prompt-box p {
        color: #ccc;
        margin: 0 0 12px 0;
        font-size: 16px;
    }

    .login-prompt-box a {
        color: #ffc107;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s;
    }

    .login-prompt-box a:hover {
        color: white;
        text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
    }

    .review-item {
        background: rgba(40, 40, 40, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-left: 5px solid #ffc107;
        margin-bottom: 20px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .review-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }

    .reviewer-avatar-img {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #ffc107;
        flex-shrink: 0;
    }

    .star-rating-display {
        color: #ffc107;
        font-size: 14px;
        margin-left: 10px;
    }

    .review-author-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .review-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    .btn-review-action {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ccc;
        padding: 6px 15px;
        border-radius: 20px;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-review-action.btn-delete:hover {
        background: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .btn-review-action.btn-edit:hover {
        background: #ffc107;
        border-color: #ffc107;
        color: black;
        font-weight: bold;
    }

    .edit-comment-form {
        display: none;
        margin-top: 15px;
        background: rgba(20, 20, 20, 0.4);
        padding: 15px;
        border-radius: 10px;
        border: 1px solid rgba(255, 215, 0, 0.1);
    }

    .edit-comment-form textarea {
        width: 100%;
        height: 80px;
        background: #111;
        border: 1px solid #444;
        color: white;
        border-radius: 8px;
        padding: 10px;
        font-size: 14px;
        resize: vertical;
        margin-bottom: 10px;
    }

    .edit-comment-form textarea:focus {
        border-color: #ffc107;
        outline: none;
    }

    .add-review-section label {
        color: #ffc107;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

    .rating-select-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 15px;
    }

    .rating-select {
        background: #1a1a1a;
        border: 1px solid #555;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        font-size: 14px;
    }

    .rating-select:focus {
        border-color: #ffc107;
        outline: none;
    }
</style>

<div class="comments-details-section">
    <h2 class="comments-section-title">💬 Audience Reviews & Comments</h2>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="add-review-section">
            <form asp-controller="Reviews" asp-action="Create" method="post">
                <input type="hidden" name="MovieId" value="@Model.MovieId" />
                
                <div class="rating-select-wrapper">
                    <label for="StarRating">Your Rating:</label>
                    <select name="StarRating" id="StarRating" class="rating-select">
                        <option value="5">⭐⭐⭐⭐⭐ (5/5)</option>
                        <option value="4">⭐⭐⭐⭐ (4/5)</option>
                        <option value="3">⭐⭐⭐ (3/5)</option>
                        <option value="2">⭐⭐ (2/5)</option>
                        <option value="1">⭐ (1/5)</option>
                    </select>
                </div>

                <textarea name="CommentText" placeholder="Write a gorgeous review about this masterpiece... What did you love? How was the performance?" required></textarea>
                
                <div class="action-row">
                    <button type="submit" class="btn-post-review">Post Review</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="login-prompt-box">
            <p>You must be authenticated to leave a review and share your custom rating.</p>
            <a asp-area="Identity" asp-page="/Account/Login">✨ Sign In / Join Golden Era Movies</a>
        </div>
    }

    <div class="reviews-list">
        @{
            var reviews = ViewBag.Reviews as List<GoldenEraMovies.Models.Review> ?? new List<GoldenEraMovies.Models.Review>();
            var avatars = ViewBag.UserAvatars as Dictionary<string, string> ?? new Dictionary<string, string>();
        }

        @if (!reviews.Any())
        {
            <p style="text-align: center; color: #888; font-style: italic; margin-top: 30px;">No audience reviews yet. Be the first to share your thoughts on this legendary film!</p>
        }
        else
        {
            @foreach (var review in reviews)
            {
                <div class="review-item" id="review-@review.ReviewId">
                    @if (avatars.ContainsKey(review.UserId ?? "") && !string.IsNullOrEmpty(avatars[review.UserId ?? ""]))
                    {
                        <img src="@avatars[review.UserId ?? ""]" alt="Avatar @review.UserId" class="reviewer-avatar-img" />
                    }
                    else
                    {
                        <div class="reviewer-avatar">
                            @(string.IsNullOrEmpty(review.UserId) ? "A" : review.UserId.Substring(0, Math.Min(2, review.UserId.Length)).ToUpper())
                        </div>
                    }

                    <div class="review-content">
                        <div class="review-header">
                            <div class="review-author-info">
                                <h4>@review.UserId</h4>
                                <span class="star-rating-display">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.StarRating)
                                        {
                                            <span>★</span>
                                        }
                                        else
                                        {
                                            <span style="color: #444;">★</span>
                                        }
                                    }
                                </span>
                            </div>
                            <span class="review-date">@review.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>

                        <p class="review-text-content">@review.CommentText</p>

                        @if (User.Identity.IsAuthenticated && (User.Identity.Name == review.UserId || User.IsInRole("Admin")))
                        {
                            <div class="review-actions">
                                <button type="button" class="btn-review-action btn-edit" onclick="toggleEditForm(@review.ReviewId)">Edit</button>
                                <form asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.ReviewId" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                    <button type="submit" class="btn-review-action btn-delete">Delete</button>
                                </form>
                            </div>

                            <!-- Formularul inline de editare -->
                            <div class="edit-comment-form" id="edit-form-@review.ReviewId">
                                <form asp-controller="Reviews" asp-action="Edit" asp-route-id="@review.ReviewId" method="post">
                                    <input type="hidden" name="ReviewId" value="@review.ReviewId" />
                                    <input type="hidden" name="MovieId" value="@review.MovieId" />
                                    <input type="hidden" name="UserId" value="@review.UserId" />
                                    <input type="hidden" name="CreatedAt" value="@review.CreatedAt.ToString("o")" />

                                    <div class="rating-select-wrapper">
                                        <label for="EditStarRating-@review.ReviewId">Update Rating:</label>
                                        <select name="StarRating" id="EditStarRating-@review.ReviewId" class="rating-select">
                                            <!option value="5" @(review.StarRating == 5 ? "selected" : "")>⭐⭐⭐⭐⭐ (5/5)</!option>
                                            <!option value="4" @(review.StarRating == 4 ? "selected" : "")>⭐⭐⭐⭐ (4/5)</!option>
                                            <!option value="3" @(review.StarRating == 3 ? "selected" : "")>⭐⭐⭐ (3/5)</!option>
                                            <!option value="2" @(review.StarRating == 2 ? "selected" : "")>⭐⭐ (2/5)</!option>
                                            <!option value="1" @(review.StarRating == 1 ? "selected" : "")>⭐ (1/5)</!option>
                                        </select>
                                    </div>

                                    <textarea name="CommentText" required>@review.CommentText</textarea>
                                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                                        <button type="button" class="btn-review-action" onclick="toggleEditForm(@review.ReviewId)">Cancel</button>
                                        <button type="submit" class="btn-review-action btn-edit">Save Changes</button>
                                    </div>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function() {
    $(".star").click(function() {
        var rv = $(this).attr("data-value");
        var mid = @Model.MovieId;
        $.post("/Movies/Rate", { id: mid, rating: rv }, function(res) {
            if(res.success) {
                alert("Rating salvat cu succes!");
                location.reload();
            } else {
                alert("Eroare la salvarea rating-ului.");
            }
        });
    });
});

function toggleEditForm(id) {
    var form = $("#edit-form-" + id);
    var textContent = $("#review-" + id).find(".review-text-content");
    var actions = $("#review-" + id).find(".review-actions");
    
    if (form.is(":visible")) {
        form.slideUp();
        textContent.slideDown();
        actions.slideDown();
    } else {
        form.slideDown();
        textContent.slideUp();
        actions.slideUp();
    }
}
</script>
