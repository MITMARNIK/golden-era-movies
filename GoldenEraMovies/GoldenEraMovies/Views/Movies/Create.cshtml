@model GoldenEraMovies.Models.Movie

@{
    ViewData["Title"] = "Add Movie";
}

<link rel="stylesheet" href="~/css/LoginRegister.css" />

<div class="auth-page-wrapper">
    <div class="auth-box" style="max-width: 600px;">
        <h2 class="auth-title" style="margin-bottom: 20px;">Add Movie</h2>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="color: red; font-size: 0.9em; margin-bottom: 15px; text-align: left;"></div>
            
            <div class="input-group">
                <input asp-for="Title" required placeholder=" " />
                <label asp-for="Title">Title</label>
                <span asp-validation-for="Title" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>
            
            <div class="input-group">
                <input asp-for="Description" required placeholder=" " />
                <label asp-for="Description">Description</label>
                <span asp-validation-for="Description" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>
            
            <div class="input-group">
                <input asp-for="ReleaseYear" required placeholder=" " type="number" />
                <label asp-for="ReleaseYear">Release Year</label>
                <span asp-validation-for="ReleaseYear" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>

            <div class="input-group">
                <input asp-for="Duration" required placeholder=" " type="number" />
                <label asp-for="Duration">Duration (minutes)</label>
                <span asp-validation-for="Duration" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>

            <div class="input-group">
                <input asp-for="PosterPath" placeholder=" " />
                <label asp-for="PosterPath">Poster URL (optional)</label>
                <span asp-validation-for="PosterPath" class="text-danger" style="color: red; font-size: 0.8em; display:block; margin-top:5px; text-align: left;"></span>
            </div>

            <button type="submit" class="auth-choice-btn btn-solid">
                Create Movie
            </button>
            
            <div style="margin-top: 20px;">
                <a asp-action="Index" class="back-link-auth">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
